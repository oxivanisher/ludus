# Copy to .env and adjust

# Container user — set to match your host user to avoid permission issues
# Defaults to 1000:1000; on Linux the shell's $UID/$GID are used automatically
UID=1000
GID=1000

# Redis connection (default works with docker-compose)
REDIS_URL=redis://redis:6379

# Session lifetime in days
SESSION_TTL_DAYS=30
FINISHED_SESSION_TTL_DAYS=3

# Your domain (used by Traefik label)
LUDUS_DOMAIN=ludus.example.com

# Web Push / VAPID keys (optional — leave empty to disable push notifications)
# Generate with: docker compose run --rm ludus python -m core.vapid_gen
VAPID_PRIVATE_KEY=
VAPID_PUBLIC_KEY=
VAPID_CONTACT_EMAIL=admin@example.com
