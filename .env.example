# Copy to .env and adjust

# Container user — set to match your host user to avoid permission issues
# Defaults to 1000:1000; on Linux the shell's $UID/$GID are used automatically
UID=1000
GID=1000

# Redis connection (default works with docker-compose)
REDIS_URL=redis://redis:6379

# Session lifetime in days
SESSION_TTL_DAYS=30
FINISHED_SESSION_TTL_DAYS=3

# Your domain (used by Traefik label)
LUDUS_DOMAIN=ludus.example.com

# Docker network Traefik is on — required when the container has multiple networks
# so Traefik knows which interface to route through (default: web)
TRAEFIK_NETWORK=web

# Abuse protection — cap concurrent sessions and public open games
MAX_ACTIVE_SESSIONS=200
MAX_PUBLIC_SESSIONS=20

# Prometheus metrics (optional — leave empty to disable)
# When set, exposes GET /metrics on the main port protected by this bearer token.
# Prometheus scrapes it over HTTPS via Traefik — no extra port or firewall rules needed.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
METRICS_TOKEN=

# Web Push / VAPID keys (optional — leave empty to disable push notifications)
# Generate with: docker compose run --rm ludus python -m core.vapid_gen
VAPID_PRIVATE_KEY=
VAPID_PUBLIC_KEY=
VAPID_CONTACT_EMAIL=admin@example.com
